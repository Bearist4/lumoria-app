    "Sometimes the moment is worth sharing with one person. Lumoria makes it one tap.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Manchmal lohnt es sich, einen Moment mit einer einzigen Person zu teilen. Lumoria macht das mit einem Tipp möglich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
