    "Drag the gallery down to resync with the cloud. Anything you've made on another device shows up right here.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehen Sie die Galerie nach unten, um mit der Cloud zu synchronisieren. Alles, was Sie auf einem anderen Gerät erstellt haben, erscheint genau hier."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pull the gallery down to refresh. Anything you made on another device shows up here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra la galería hacia abajo para volver a sincronizar con la nube. Todo lo que hayas creado en otro dispositivo aparecerá aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tirez la galerie vers le bas pour la synchroniser avec le cloud. Tout ce que vous avez créé sur un autre appareil apparaît ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Trascina verso il basso la galleria per sincronizzarla con il cloud. Tutto ciò che hai creato su un altro dispositivo apparirà qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ギャラリーを下に引いてクラウドと再同期します。別のデバイスで作成したものがここに表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "갤러리를 아래로 당겨 클라우드와 다시 동기화하세요. 다른 기기에서 만든 항목이 여기에 표시됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下拉图库以重新与云端同步。您在其他设备上创建的内容会显示在这里。"
          }
        }
      }
    },
