    "You've used your invite. Delete a memory or a ticket to make room for a new one.": {
      "comment": "Invite landing — redeemed-state body",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben Ihre Einladung bereits genutzt. Löschen Sie eine Erinnerung oder ein Ticket, um Platz für etwas Neues zu schaffen."
