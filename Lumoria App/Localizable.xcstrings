    "Your theme and colour picks will revert to the template's default.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Design und Ihre Farbauswahl werden auf die Standardwerte der Vorlage zurückgesetzt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
