    "This permanently removes your profile, tickets, memories, and invites. This cannot be undone." : {
      "comment" : "A message displayed when the user is about to delete their account.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Damit werden Ihr Profil, Ihre Tickets, Erinnerungen und Einladungen unwiderruflich gelöscht. Dieser Vorgang kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This permanently removes your profile, tickets, memories, and invites. This cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará de forma permanente su perfil, sus boletos, sus recuerdos y sus invitaciones. La acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette action supprime définitivement votre profil, vos billets, vos souvenirs et vos invitations. Elle est irréversible."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa operazione rimuoverà definitivamente il suo profilo, i biglietti, i ricordi e gli inviti. Non potrà essere annullata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プロフィール・チケット・メモリー・招待がすべて完全に削除されます。この操作は取り消せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "프로필, 티켓, 메모리, 초대가 모두 영구적으로 삭제됩니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此操作将永久删除您的个人资料、票券、回忆与邀请,且无法撤销。"
          }
        }
      }
    },
    "This ticket is not part of a memory. Memories help you group tickets by trip, event, or place." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Ticket gehört noch zu keiner Erinnerung. Verbinde es mit einer, damit die Reise beisammen bleibt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This ticket isn’t part of any memory yet. Pair it with one to keep the trip together."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este ticket aún no forma parte de ninguna memoria. Vincúlalo con una para mantener el viaje unido."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce billet n’appartient encore à aucun souvenir. Associez-le pour garder le voyage ensemble."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo biglietto non fa ancora parte di nessun ricordo. Abbinalo a uno per tenere il viaggio unito."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
