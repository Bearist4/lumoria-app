    "Give it to someone who'll love it. When they join, you both get a new memory.": {
      "comment": "Description of the benefits of sending an invitation.",
      "extractionState": "manual",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geben Sie sie jemandem, der sich freut. Wenn diese Person beitritt, erhalten Sie beide eine neue Erinnerung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Give it to someone who’ll love it. When they join, you both get a new memory."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dásela a alguien a quien le encantará. Cuando se una, ambos recibiréis un nuevo recuerdo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Offrez-la à quelqu'un qui l'appréciera. Quand cette personne nous rejoint, vous recevez tous les deux un nouveau souvenir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Regalala a qualcuno che la apprezzerà. Quando si unisce, entrambi ottenete un nuovo ricordo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "喜んでくれる相手に贈りましょう。その人が参加すると、お互いに新しい思い出が手に入ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "좋아할 사람에게 보내세요. 그 사람이 가입하면 두 분 모두 새 추억을 얻습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "送给会喜欢的人。当对方加入时，你们都将获得一段新回忆。"
          }
        }
      }
    },
