    "Memories gather tickets into one place — a trip, a season, a night out. Whatever you want to hold onto.": {
      "comment": "A description of Lumoria's function.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erinnerungen bündeln Ihre Tickets an einem Ort – eine Reise, eine Saison, ein Abend. Genau das, was Sie festhalten möchten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Memories gather tickets into one place — a trip, a season, a night out. Whatever you want to hold onto."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los recuerdos reúnen sus boletos en un solo lugar: un viaje, una temporada, una noche. Lo que quiera conservar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les souvenirs rassemblent vos billets en un seul endroit : un voyage, une saison, une soirée. Tout ce que vous souhaitez conserver."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I ricordi raccolgono i suoi biglietti in un unico luogo: un viaggio, una stagione, una serata. Tutto ciò che desidera conservare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メモリーは旅行・シーズン・夜のお出かけなど、思い出のチケットをひとつにまとめます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메모리는 여행, 한 시즌, 즐거운 밤 등 간직하고 싶은 티켓을 한곳에 모아 줍니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "回忆将您的票券集中在一处——一次旅行、一个季节、一个夜晚,留住每一段值得珍藏的时刻。"
          }
        }
      }
    },
    "Memories gather tickets into one place. Create one by tapping the + button.": {
      "comment": "Tip to create a memory.",
      "extractionState": "manual",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erinnerungen sammeln Tickets an einem Ort. Tippen Sie auf +, um eine zu erstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Memories gather tickets into one place. Tap + to create one."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los recuerdos reúnen los boletos en un solo lugar. Crea uno tocando el botón +."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les souvenirs rassemblent les billets en un seul endroit. Touchez + pour en créer un."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I ricordi raccolgono i biglietti in un solo posto. Tocca il pulsante + per crearne uno."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "思い出はチケットを1か所に集めます。+ボタンをタップして作成しましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
