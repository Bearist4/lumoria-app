    "Permanently yours. No expiry, no catch.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bleibt dauerhaft Ihrs. Keine Frist, kein Haken."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Permanently yours. No expiry, no catch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tuyo para siempre. Sin caducidad, sin trampas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À vous pour toujours. Sans expiration, sans piège."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tuo per sempre. Nessuna scadenza, nessun trucco."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "永続的にあなたのものに。期限も落とし穴もありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "영구적으로 당신 것입니다. 만료도 함정도 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "永久属于你。无期限、无套路。"
          }
        }
      }
    },
    "Pick a `.pkpass` from Files and we’ll prefill every field we can read.": {
