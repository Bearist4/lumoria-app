    "Revoking your status means that you will lose benefits associated with being an early adopter. Your current content will remain but will be locked.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit dem Widerruf Ihres Status verlieren Sie die mit dem Early-Adopter-Status verbundenen Vorteile. Ihre bestehenden Inhalte bleiben erhalten, werden aber gesperrt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ll lose your early adopter benefits. Anything you’ve made stays — but it’ll be locked."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revocar tu estado significa perder los beneficios de early adopter. Tu contenido actual se conserva, pero quedará bloqueado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Révoquer votre statut signifie perdre les avantages liés à l'early adopter. Votre contenu actuel reste mais sera verrouillé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Revocare il tuo stato significa perdere i vantaggi dell'early adopter. I contenuti attuali restano ma saranno bloccati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ステータスを取り消すと、アーリーアダプターの特典は失われます。既存のコンテンツは保持されますがロックされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "상태를 철회하면 얼리어답터 혜택을 잃게 됩니다. 기존 콘텐츠는 남지만 잠깁니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "撤销您的状态将失去早期使用者的福利。现有内容仍会保留，但会被锁定。"
          }
        }
      }
    },
