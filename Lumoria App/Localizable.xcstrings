    },
    "This one is permanent — there's no undo, so choose with care.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Auswahl ist endgültig – es gibt keine Rückgängig-Funktion, wählen Sie also sorgfältig."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This one is permanent — there’s no undo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta es permanente — no hay deshacer, así que elige con cuidado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Celle-ci est définitive — pas de retour en arrière, choisissez avec soin."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa scelta è definitiva — non si può tornare indietro, scegli con attenzione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これは恒久的な選択です — 取り消しはできないため、慎重にお選びください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 선택은 영구적입니다 — 되돌릴 수 없으니 신중히 선택하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此选择不可撤销 —— 请慎重选择。"
          }
        }
      }
    },
    "This pass doesn’t match the selected template.": {
