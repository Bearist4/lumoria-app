    "We sent a confirmation link to %@. Tap it on this iPhone to activate your account, then log in.": {
      "comment": "A confirmation alert that appears when a user successfully creates an account. The argument is the user's email address.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir haben einen Bestätigungslink an %@ gesendet. Tippen Sie ihn auf diesem iPhone an, um Ihr Konto zu aktivieren, und melden Sie sich anschließend an."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviamos un enlace de confirmación a %@. Tócalo en este iPhone para activar tu cuenta y luego inicia sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous avons envoyé un lien de confirmation à %@. Touchez-le sur cet iPhone pour activer votre compte, puis connectez-vous."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abbiamo inviato un link di conferma a %@. Toccalo su questo iPhone per attivare l'account, poi accedi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "確認リンクを %@ に送信しました。このiPhoneでタップしてアカウントを有効化し、ログインしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@(으)로 확인 링크를 보냈습니다. 이 iPhone에서 링크를 눌러 계정을 활성화한 다음 로그인하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们已向 %@ 发送确认链接。请在此 iPhone 上点按链接以激活账户，然后登录。"
          }
        }
      }
    },
    "We sent a confirmation link to %@. Tap it on this iPhone to activate your account, then log in. You can't log in until your email is verified.": {
      "comment": "A message in an alert that appears after a user signs up. The argument is the string “”.",
      "extractionState": "manual",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir haben einen Bestätigungslink an %@ gesendet. Tippen Sie ihn auf diesem iPhone an, um Ihr Konto zu aktivieren, und melden Sie sich anschließend an. Bis Ihre E-Mail-Adresse bestätigt ist, ist eine Anmeldung nicht möglich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We sent a confirmation link to %@. Open it on this iPhone to activate your account — sign-in unlocks once your email is verified."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviamos un enlace de confirmación a %@. Tócalo en este iPhone para activar tu cuenta y luego inicia sesión. No podrás iniciar sesión hasta verificar tu correo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous avons envoyé un lien de confirmation à %@. Touchez-le sur cet iPhone pour activer votre compte, puis connectez-vous. Vous ne pourrez pas vous connecter tant que votre e-mail n'aura pas été vérifié."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abbiamo inviato un link di conferma a %@. Toccalo su questo iPhone per attivare l'account, poi accedi. Non potrai accedere finché l'e-mail non sarà verificata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "確認リンクを %@ に送信しました。このiPhoneでタップしてアカウントを有効化し、ログインしてください。メールアドレスが確認されるまでログインできません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@(으)로 확인 링크를 보냈습니다. 이 iPhone에서 링크를 눌러 계정을 활성화한 다음 로그인하세요. 이메일 인증 전에는 로그인할 수 없습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们已向 %@ 发送确认链接。请在此 iPhone 上点按链接以激活账户，然后登录。邮箱未验证前无法登录。"
          }
        }
      }
    },
    "We’ll auto-fill the city and drop a pin on the map.": {
