          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Depuis l'écran Collections ou Tous les billets, touchez le + pour ouvrir l'entonnoir de billets."
          }
        },
        "it": {
          "stringUnit": {
