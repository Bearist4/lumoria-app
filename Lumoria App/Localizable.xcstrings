    "You have currently %lld %@. You reached the maximum limit of %@ you can have on a regular account.": {
      "comment": "A copy that informs the user of the current count of their limited resource and the maximum limit. The second argument is the value of the localized string key “memories”, the string “items” or the value of the localized string key “tickets”. The third argument is the value of the localized string key “memories”, the string “items” or the value of the localized string key “tickets”.",
      "extractionState": "manual",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben derzeit %lld %@. Sie haben das Maximum an %@ erreicht, das in einem regulären Konto möglich ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have %1$lld %2$@ — that’s the limit on a free account."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tienes %lld %@ actualmente. Has alcanzado el límite máximo de %@ que puede tener una cuenta normal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez actuellement %lld %@. Vous avez atteint la limite maximale de %@ qu'un compte standard peut avoir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai attualmente %lld %@. Hai raggiunto il limite massimo di %@ consentito su un account standard."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在 %lld %@ をお持ちです。通常アカウントで保持できる %@ の上限に達しました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 %lld %@(을)를 가지고 있습니다. 일반 계정에서 가질 수 있는 %@ 최대 한도에 도달했습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你当前有 %lld %@。已达到普通账户最多可拥有的 %@ 上限。"
          }
        }
      }
    },
    "You have no memories yet. To create a memory, tap the + icon.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Erinnerungen. Starte deine erste mit dem + oben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No memories yet. Start your first one with the + above."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no tienes memorias. Empieza la primera con el + de arriba."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun souvenir pour l’instant. Commencez le premier avec le + ci-dessus."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancora nessun ricordo. Inizia il tuo primo con il + qui sopra."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだメモリーがありません。上の + から最初のひとつを始めましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 추억이 없어요. 위의 + 버튼으로 첫 추억을 만들어 보세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有回忆。用上方的 + 开始第一段吧。"
          }
        }
      }
    },
    "You have one invite to give. When your friend joins and creates their first ticket, a new memory unlocks for you both. Once your invite is redeemed, it's gone. Make it count.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben eine Einladung zu vergeben. Wenn Ihr Freund beitritt und sein erstes Ticket erstellt, wird für Sie beide eine neue Erinnerung freigeschaltet. Sobald die Einladung eingelöst ist, ist sie weg. Nutzen Sie sie sinnvoll."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have one invite. When your friend joins and saves their first ticket, you both unlock a memory. One use only — make it count."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tienes una invitación para regalar. Cuando tu amigo se una y cree su primer boleto, se desbloqueará un nuevo recuerdo para ambos. Una vez canjeada, desaparece. Aprovéchala bien."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez une invitation à offrir. Lorsque votre ami rejoint et crée son premier billet, un nouveau souvenir se débloque pour vous deux. Une fois utilisée, l'invitation disparaît. Faites-la compter."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai un invito da regalare. Quando il tuo amico si iscrive e crea il primo biglietto, si sblocca un nuovo ricordo per entrambi. Una volta riscattato, l'invito sparisce. Usalo bene."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "招待は1つだけです。友達が参加して最初のチケットを作成すると、お二人に新しい思い出が解放されます。一度使うとなくなりますので、大切に使ってください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "초대권은 하나입니다. 친구가 가입하고 첫 티켓을 만들면 두 분 모두에게 새 추억이 잠금 해제됩니다. 한 번 사용하면 사라지니 신중히 사용하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你只有一次邀请机会。当朋友加入并创建第一张票券时，你们都会解锁一段新的回忆。邀请一旦使用便会消失，请慎重使用。"
          }
        }
      }
    },
