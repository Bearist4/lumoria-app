    "Full access from day one. Cancel before day 15 and you won't be charged anything.": {
      "comment": "A description of the benefits of the trial.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vom ersten Tag an voller Zugriff. Wenn Sie vor dem 15. Tag kündigen, wird Ihnen nichts berechnet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Full access from day one. Cancel before day 15 and you won't be charged anything."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acceso completo desde el primer día. Si cancela antes del día 15, no se le cobrará nada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accès complet dès le premier jour. Si vous résiliez avant le 15ᵉ jour, rien ne vous sera facturé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesso completo dal primo giorno. Se annulla entro il 15° giorno, non le verrà addebitato nulla."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "初日から全機能をご利用いただけます。15日目より前に解約すれば、料金は一切かかりません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "첫날부터 모든 기능을 이용하실 수 있습니다. 15일 차 이전에 취소하시면 요금이 청구되지 않습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
