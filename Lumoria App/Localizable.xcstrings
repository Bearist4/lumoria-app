    "Tap Camera roll to save your ticket as an image in your photo library." : {
      "comment" : "Tip body text for the onboarding overlay when the user is exporting a ticket.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippen Sie auf „Fotoalbum“, um Ihr Ticket als Bild in Ihrer Fotomediathek zu speichern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap Camera roll to save your ticket as an image in your photo library."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pulse «Carrete» para guardar su boleto como imagen en su biblioteca de fotos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez sur « Pellicule » pour enregistrer votre billet sous forme d’image dans votre photothèque."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocchi «Rullino» per salvare il biglietto come immagine nella libreria foto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「カメラロール」をタップすると、チケットを写真ライブラリに画像として保存できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "‘사진’을 탭하면 티켓을 이미지로 사진 보관함에 저장할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点按「相册」即可将您的票券保存为图片到照片图库中。"
          }
        }
      }
    },
    "Tap the link we sent to %@ to activate your account, then log in. Check your spam folder if you don't see it." : {
      "comment" : "A message in an alert that appears when the user taps the \"Resend email\" button in the \"Verify your email\" alert. The argument is the user's email address.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippen Sie auf den Link, den wir an %@ gesendet haben, um Ihr Konto zu aktivieren, und melden Sie sich anschließend an. Schauen Sie ggf. in Ihrem Spam-Ordner nach."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the link we sent to %@ to activate your account, then log in. Check your spam folder if you don't see it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pulse el enlace que enviamos a %@ para activar su cuenta y, después, inicie sesión. Revise la carpeta de correo no deseado si no lo ve."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez sur le lien que nous avons envoyé à %@ pour activer votre compte, puis connectez-vous. Pensez à vérifier votre dossier de courrier indésirable si vous ne le voyez pas."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocchi il link che abbiamo inviato a %@ per attivare il suo account, poi acceda. Se non lo trova, controlli la cartella spam."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ に送信したリンクをタップしてアカウントを有効化し、ログインしてください。届いていない場合は迷惑メールフォルダーをご確認ください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@(으)로 보내 드린 링크를 탭하여 계정을 활성화한 뒤 로그인해 주세요. 메일이 보이지 않는다면 스팸 메일함도 확인해 보세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请点按我们发送至 %@ 的链接以激活您的账户,然后登录。若未收到邮件,请检查垃圾邮件文件夹。"
          }
        }
      }
    },
    "Tap the memory you would like to add your ticket to. This can be changed later." : {
      "comment" : "Tip to show when onboarding the Add to Memory sheet.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippen Sie auf die Erinnerung, zu der Sie Ihr Ticket hinzufügen möchten. Sie können das später ändern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the memory you would like to add your ticket to. This can be changed later."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pulse el recuerdo al que desee añadir su boleto. Podrá cambiarlo más tarde."
