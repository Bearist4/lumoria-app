    "From the Collections or All tickets screen, tap the + to open the ticket funnel.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie auf dem Bildschirm Sammlungen oder Alle Tickets auf das +, um den Ticket-Funnel zu öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From Collections or All tickets, tap + to start a new ticket."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
