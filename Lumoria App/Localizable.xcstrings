    "Tip: a 3x PNG with gradient off is the sharpest cutout for Stories, wallpapers, and further editing.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tipp: Ein 3x-PNG ohne Verlauf liefert das schärfste Cutout für Stories, Wallpaper und weitere Bearbeitungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Tip: a 3x PNG with gradient off is the sharpest cutout for Stories, wallpapers, and further editing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consejo: un PNG 3x con el degradado desactivado es el recorte más nítido para historias, fondos y posteriores ediciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Astuce : un PNG 3x sans dégradé donne la découpe la plus nette pour les Stories, les fonds d'écran et les retouches."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Suggerimento: un PNG 3x con il gradiente disattivato è il ritaglio più nitido per Storie, sfondi e modifiche successive."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ヒント：グラデーションをオフにした3倍PNGはストーリーや壁紙、さらなる編集に最も鮮明なカットアウトを提供します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "팁: 그라데이션을 끈 3x PNG는 스토리, 배경화면, 추가 편집에 가장 선명한 컷아웃입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提示：关闭渐变的 3x PNG 是用于故事、壁纸或进一步编辑的最清晰抠图。"
          }
        }
      }
    },
