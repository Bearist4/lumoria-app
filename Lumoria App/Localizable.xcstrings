    "We filled in %@ for you. Edit the ticket later to swap the copy.": {
      "comment": "A footnote explaining that the ticket was filled with placeholder copy. The argument is a list of field names.",
      "extractionState": "manual",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir haben %@ für Sie ausgefüllt. Bearbeiten Sie das Ticket später, um den Text auszutauschen."
          }
        },
