    "We sent a confirmation link to %@. Open it to activate your account, then sign in here.": {
      "comment": "A confirmation alert that appears when a user successfully signs up. The argument is the string “”.",
      "extractionState": "stale",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schau in %@ — wir haben dir einen Bestätigungslink gesendet. Öffne ihn, komm zurück und melde dich an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check %@ — we’ve sent a link to confirm your account. Open it, then come back and sign in."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisa %@ — te hemos enviado un enlace para confirmar tu cuenta. Ábrelo, vuelve y inicia sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Consultez %@ — nous vous avons envoyé un lien pour confirmer votre compte. Ouvrez-le, revenez ici et connectez-vous."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Controlla %@ — ti abbiamo inviato un link per confermare il tuo account. Aprilo, torna qui e accedi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ をご確認ください — アカウント確認用のリンクをお送りしました。リンクを開いたあと、ここに戻ってサインインしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 메일함을 확인해 주세요 — 계정 확인 링크를 보내드렸어요. 링크를 연 뒤 이 화면으로 돌아와 로그인해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "查收 %@ — 我们发送了一封账户确认邮件。打开链接后回到这里登录。"
          }
        }
      }
    },
    "We sent a confirmation link to %@. Open it to activate your account, then sign in.": {
