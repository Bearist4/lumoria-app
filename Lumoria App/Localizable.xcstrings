    "Export with PNG, Full crop, 3x resolution, background gradient off. Watermark is your call.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit PNG, vollständigem Zuschnitt, 3-facher Auflösung, ohne Hintergrundverlauf exportieren. Wasserzeichen ist Ihre Entscheidung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PNG, full crop, 3x resolution, gradient off. Watermark is your call."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporta en PNG, recorte completo, resolución 3x y sin degradado de fondo. La marca de agua es tu elección."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportez en PNG, recadrage complet, résolution 3x, sans dégradé de fond. Le filigrane est à votre choix."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esporta in PNG, ritaglio completo, risoluzione 3x, senza gradiente di sfondo. La filigrana è una tua scelta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PNG、フルクロップ、3倍解像度、背景グラデーションオフで書き出します。透かしの有無はお好みで。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "PNG, 전체 자르기, 3배 해상도, 배경 그라데이션 끄기로 내보내세요. 워터마크는 선택입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "以 PNG、完整裁切、3x 分辨率、关闭背景渐变导出。水印由你决定。"
          }
        }
      }
    },
