    "Become an early adopter to get unlimited %@ or delete older %@ before creating new ones.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Werden Sie Early Adopter, um unbegrenzt %@ zu erhalten, oder löschen Sie ältere %@, bevor Sie neue erstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Become an early adopter for unlimited %1$@, or delete older %2$@ to make room."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hazte early adopter para obtener %@ ilimitados o elimina %@ antiguos antes de crear nuevos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Devenez early adopter pour obtenir des %@ illimités, ou supprimez d'anciens %@ avant d'en créer de nouveaux."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Diventa early adopter per ottenere %@ illimitati, oppure elimina %@ più vecchi prima di crearne di nuovi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アーリーアダプターになって %@ を無制限に利用するか、新しいものを作成する前に古い %@ を削除してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "얼리어답터가 되어 %@(을)를 무제한으로 사용하거나, 새 항목을 만들기 전에 오래된 %@(을)를 삭제하세요."
