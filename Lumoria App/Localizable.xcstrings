      }
    },
    "You will get a reminder that your trial is about to expire.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie erhalten eine Erinnerung, dass Ihr Probezeitraum bald abläuft."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We’ll remind you before your trial ends."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibirás un aviso de que tu prueba está por terminar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous recevrez un rappel indiquant que votre essai arrive à expiration."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riceverai un promemoria che la prova sta per scadere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トライアルがまもなく終了することをお知らせします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "체험이 곧 종료된다는 알림을 받게 됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你将收到试用即将到期的提醒。"
          }
        }
      }
    },
    "You'll fall back to the Free tier limits. Existing memories and tickets stay but new ones will be capped again.": {
      "comment": "A message displayed in a confirmation alert when revoking an early-adopter status.",
      "extractionState": "manual",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie kehren zu den Free-Tarif-Grenzen zurück. Bestehende Erinnerungen und Tickets bleiben, neue werden jedoch wieder begrenzt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ll go back to Free tier limits. Anything you’ve made stays — new ones will be capped again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Volverás a los límites del plan gratuito. Los recuerdos y boletos existentes se conservan, pero los nuevos volverán a estar limitados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous reviendrez aux limites du forfait gratuit. Les souvenirs et billets existants restent, mais les nouveaux seront à nouveau plafonnés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tornerai ai limiti del piano gratuito. I ricordi e biglietti esistenti restano, ma quelli nuovi saranno di nuovo limitati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無料プランの上限に戻ります。既存の思い出とチケットは残りますが、新規は再び制限されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "무료 요금제 한도로 돌아갑니다. 기존 추억과 티켓은 유지되지만 새 항목은 다시 제한됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你将退回到免费层的限制。已有回忆和票券保留，但新内容将再次受限。"
          }
        }
      }
    },
    "You'll get a new invite to share. The current link will stop working.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der aktuelle Link funktioniert nicht mehr. Eine neue Einladung tritt an seine Stelle."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your current link will stop working. A fresh invite takes its place."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu enlace actual dejará de funcionar. Una invitación nueva ocupará su lugar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre lien actuel cessera de fonctionner. Une nouvelle invitation prend le relais."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo link attuale smetterà di funzionare. Al suo posto arriva un nuovo invito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のリンクは無効になります。代わりに新しい招待が発行されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 링크는 더 이상 작동하지 않습니다. 대신 새 초대가 발급됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前链接将失效，一份新的邀请会取而代之。"
          }
        }
      }
    },
    "You'll land back in the ticket funnel with every field already filled in. Update anything — airline, date, seat, gate, passenger name, orientation. Every change previews live.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie landen wieder im Ticket-Funnel, in dem alle Felder bereits ausgefüllt sind. Ändern Sie, was Sie wollen – Fluggesellschaft, Datum, Platz, Gate, Passagiername, Ausrichtung. Jede Änderung wird live in der Vorschau angezeigt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ll head back to the form with every field filled in. Update anything — airline, date, seat, gate, name, orientation. The preview updates live."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Volverás al embudo de boletos con todos los campos ya rellenados. Cambia lo que quieras — aerolínea, fecha, asiento, puerta, nombre del pasajero, orientación. Cada cambio se previsualiza al instante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous reviendrez à l'entonnoir de billet avec tous les champs déjà remplis. Modifiez ce que vous voulez — compagnie, date, siège, porte, nom du passager, orientation. Chaque changement est prévisualisé en direct."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tornerai al flusso del biglietto con tutti i campi già compilati. Modifica ciò che vuoi — compagnia, data, posto, gate, nome del passeggero, orientamento. Ogni modifica viene visualizzata in tempo reale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての項目があらかじめ入力された状態でチケットファネルに戻ります。航空会社、日付、座席、ゲート、搭乗者名、向きなど、自由に変更してください。すべての変更がリアルタイムでプレビューされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 항목이 이미 채워진 상태로 티켓 만들기 흐름에 다시 돌아갑니다. 항공사, 날짜, 좌석, 게이트, 승객 이름, 방향 등 무엇이든 수정하세요. 모든 변경이 실시간으로 미리보기됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你将回到票券创建流程，所有字段都已填好。可任意修改 —— 航司、日期、座位、登机口、乘客姓名、方向，所有改动都会实时预览。"
          }
        }
      }
    },
    "You're at the Free tier limit of %lld memories. Delete an older memory to free this one up, or become an early adopter for unlimited slots.": {
      "comment": "A message in the locked-memory alert. The argument is the number of memories the user can have.",
      "extractionState": "manual",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben die Free-Tarif-Grenze von %lld Erinnerungen erreicht. Löschen Sie eine ältere Erinnerung, um Platz zu schaffen, oder werden Sie Early Adopter für unbegrenzte Plätze."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ve hit the Free tier limit of %lld memories. Delete one to make room — or become an early adopter for unlimited slots."
