    "You only get one invite, ever. Make it count.": {
      "comment": "A footer caption for the invite explanation view.",
      "extractionState": "manual",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben nur eine einzige Einladung. Nutzen Sie sie sinnvoll."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One invite, ever. Make it count."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo recibes una invitación. Aprovéchala bien."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous n'avez qu'une seule invitation. Faites-la compter."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai un solo invito, in tutto. Usalo bene."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "招待は一度きりです。大切に使ってください。"
          }
        },
        "ko": {
