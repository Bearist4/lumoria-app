    "Tap All tickets from the home screen.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie auf dem Home-Bildschirm auf „Alle Tickets“."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap All tickets on the home screen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca Todos los boletos en la pantalla principal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez Tous les billets sur l'écran d'accueil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca Tutti i biglietti dalla schermata principale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホーム画面から「すべてのチケット」をタップします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "홈 화면에서 모든 티켓을 누르세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在主屏幕点按“全部票券”。"
          }
        }
      }
    },
    "Tap any ticket to drop it into the thread. Tap and hold to place it on top of another message.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie auf ein Ticket, um es in den Chat einzufügen. Halten Sie gedrückt, um es über einer anderen Nachricht zu platzieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Tap any ticket to drop it into the thread. Tap and hold to place it on top of another message."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca cualquier boleto para soltarlo en la conversación. Toca y mantén pulsado para colocarlo sobre otro mensaje."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez un billet pour le déposer dans la conversation. Maintenez pour le poser sur un autre message."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca un biglietto per inserirlo nella conversazione. Tocca e tieni premuto per posarlo sopra un altro messaggio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チケットをタップしてスレッドに送ります。長押しすると他のメッセージの上に重ねられます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "티켓을 누르면 대화에 추가됩니다. 길게 누르면 다른 메시지 위에 올릴 수 있어요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点按任意票券即可放入对话。按住可叠放在其他消息上。"
          }
        }
      }
    },
    "Tap Camera roll to save your ticket as an image in your photo library.": {
      "comment": "Tip body text for the onboarding overlay when the user is exporting a ticket.",
      "extractionState": "manual",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie auf „Fotos“, um Ihr Ticket als Bild in Ihrer Mediathek zu speichern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap Camera roll to save your ticket as an image."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca Carrete para guardar tu boleto como imagen en tu fototeca."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez Pellicule pour enregistrer votre billet en tant qu'image dans votre bibliothèque photo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca Rullino per salvare il biglietto come immagine nella libreria foto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「カメラロール」をタップしてチケットを写真ライブラリに画像として保存します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "카메라 롤을 눌러 티켓을 사진 보관함에 이미지로 저장하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点按相册即可将票券保存为图片至照片图库。"
          }
        }
      }
    },
