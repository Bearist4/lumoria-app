    "Wrote the seat number wrong? Mistyped a gate? No problem. Every ticket stays editable forever.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Falsche Platznummer? Tippfehler beim Gate? Kein Problem. Jedes Ticket bleibt für immer bearbeitbar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Wrote the seat number wrong? Mistyped a gate? No problem. Every ticket stays editable forever."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Te equivocaste con el asiento? ¿Tecleaste mal la puerta? No pasa nada. Todos los boletos siguen editables para siempre."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mauvais numéro de siège ? Faute de frappe sur la porte ? Pas de souci. Chaque billet reste modifiable à jamais."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Numero del posto sbagliato? Refuso sul gate? Nessun problema. Ogni biglietto resta modificabile per sempre."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "座席番号を間違えましたか？ゲートを打ち間違えましたか？大丈夫です。すべてのチケットはいつでも編集可能です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "좌석 번호를 잘못 적었거나 게이트를 잘못 입력했나요? 괜찮습니다. 모든 티켓은 언제든 수정할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
