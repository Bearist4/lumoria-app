          }
        }
      }
    },
    "Your ticket has been created. You can find it in All Tickets. You can now add it to a Memory or Export your ticket to use it in another app.": {
      "comment": "Tip body for the onboarding overlay in the NewTicketSuccessStep.",
      "extractionState": "manual",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Ticket wurde erstellt. Sie finden es unter „Alle Tickets“. Sie können es nun zu einer Erinnerung hinzufügen oder exportieren, um es in einer anderen App zu verwenden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your ticket is saved. Find it in All tickets — add it to a memory, or export it anywhere."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu boleto se ha creado. Lo encontrarás en Todos los boletos. Ya puedes añadirlo a un recuerdo o exportarlo para usarlo en otra app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre billet a été créé. Vous le retrouverez dans Tous les billets. Vous pouvez désormais l'ajouter à un souvenir ou l'exporter pour l'utiliser dans une autre application."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo biglietto è stato creato. Lo trovi in Tutti i biglietti. Ora puoi aggiungerlo a un ricordo o esportarlo per usarlo in un'altra app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チケットを作成しました。「すべてのチケット」からご覧いただけます。思い出に追加するか、書き出して他のアプリで利用できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "티켓이 만들어졌습니다. 모든 티켓에서 확인할 수 있습니다. 이제 추억에 추가하거나 내보내기로 다른 앱에서 사용해 보세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的票券已创建，可在“全部票券”中查看。现在可加入回忆或导出到其他应用中使用。"
          }
        }
      }
    },
