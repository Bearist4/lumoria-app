    "Leave now? Your ticket won't be saved." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du jetzt gehst, wird dieses Ticket nicht gespeichert. Du hast schon eine Weile daran gearbeitet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leave now and this ticket won’t be saved. You’ve been crafting it for a while."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si sales ahora, este ticket no se guardará. Llevas un rato creándolo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous partez maintenant, ce billet ne sera pas enregistré. Vous le façonnez depuis un moment."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
