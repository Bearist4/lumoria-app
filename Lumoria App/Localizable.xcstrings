    "We filled in %@ for you. Edit the ticket later to swap the copy." : {
      "comment" : "A footnote explaining that the ticket was filled with placeholder copy. The argument is a list of field names.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir haben %@ für Sie ausgefüllt. Sie können das Ticket später bearbeiten, um den Text zu ändern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We filled in %@ for you. Edit the ticket later to swap the copy."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hemos rellenado %@ por usted. Puede editar el boleto más tarde para cambiar el texto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous avons rempli %@ pour vous. Vous pourrez modifier le billet plus tard pour changer le texte."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abbiamo compilato %@ per lei. Può modificare il biglietto in seguito per sostituire il testo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ を自動入力しました。後でチケットを編集して内容を変更できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@을(를) 대신 채워 두었습니다. 나중에 티켓을 편집해 내용을 바꿀 수 있어요."
