    "The app picks up where Wallet left off. Lumoria reads the pass, matches the fields, and moves you straight to the form.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die App setzt dort an, wo Wallet aufhört. Lumoria liest den Pass, ordnet die Felder zu und führt Sie direkt zum Formular."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "The app picks up where Wallet left off. Lumoria reads the pass, matches the fields, and moves you straight to the form."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La app continúa donde Wallet lo dejó. Lumoria lee el pase, mapea los campos y te lleva directo al formulario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'application reprend là où Wallet s'arrête. Lumoria lit le pass, fait correspondre les champs et vous mène directement au formulaire."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app riprende da dove Wallet si è fermato. Lumoria legge il pass, abbina i campi e ti porta direttamente al modulo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリはWalletの続きから始まります。Lumoriaがパスを読み取り、フィールドを照合してフォームへ直接移動します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Wallet에서 멈춘 지점에서 앱이 이어받습니다. Lumoria가 패스를 읽고 필드를 매칭한 뒤 양식 화면으로 바로 안내합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用从 Wallet 中断处接力。Lumoria 读取通行证、映射字段，并直接带你进入表单。"
          }
        }
      }
    },
    "The camera-roll export panel slides up with every control you need.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Export-Panel für die Fotos-App schiebt sich nach oben – mit allen Steuerelementen, die Sie brauchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "The camera-roll export panel slides up with every control you need."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El panel de exportación al carrete sube con todos los controles que necesitas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le panneau d'export vers la pellicule s'ouvre avec tous les contrôles nécessaires."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il pannello di esportazione nel rullino appare con tutti i controlli necessari."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラロール書き出しパネルが必要なコントロールとともにスライドアップします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "카메라 롤 내보내기 패널이 필요한 모든 컨트롤과 함께 올라옵니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出到相册的面板会带着你需要的所有控件滑出。"
          }
        }
      }
    },
    "The date displayed on the ticket": {
