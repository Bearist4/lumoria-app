        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has alcanzado el límite del plan gratuito de %lld recuerdos. Elimina un recuerdo antiguo para liberar uno, o hazte early adopter para tener espacios ilimitados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez atteint la limite du forfait gratuit de %lld souvenirs. Supprimez un ancien souvenir pour libérer un emplacement, ou devenez early adopter pour des emplacements illimités."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai raggiunto il limite del piano gratuito di %lld ricordi. Elimina un ricordo più vecchio per liberare un posto, o diventa early adopter per posti illimitati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無料プランの上限 %lld 件の思い出に達しました。古い思い出を削除して空きを作るか、アーリーアダプターになって無制限の枠を手に入れましょう。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "무료 요금제 한도인 추억 %lld개에 도달했습니다. 오래된 추억을 삭제해 자리를 비우거나 얼리어답터가 되어 무제한 슬롯을 사용하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已达到免费层 %lld 个回忆的上限。删除一个旧回忆腾出空间，或成为早期使用者享受不限名额。"
          }
        }
      }
    },
