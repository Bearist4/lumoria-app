    "Tap Done. Your ticket updates everywhere it lives — your gallery, your iMessage sticker pack, your memories.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie auf „Fertig“. Ihr Ticket wird überall aktualisiert – in Ihrer Galerie, im iMessage-Sticker-Pack und in Ihren Erinnerungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap Done. Your ticket updates everywhere — gallery, sticker pack, memories."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca Listo. Tu boleto se actualiza en todos sus lugares — tu galería, tu pack de stickers de iMessage y tus recuerdos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez Terminé. Votre billet est mis à jour partout où il existe — votre galerie, votre pack de stickers iMessage, vos souvenirs."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca Fine. Il biglietto si aggiorna ovunque si trovi — galleria, pacchetto sticker iMessage e ricordi."
