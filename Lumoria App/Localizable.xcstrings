          }
        }
      }
    },
    "We sent a confirmation link to %@. Tap it on this iPhone to activate your account, then log in. You can't log in until your email is verified." : {
      "comment" : "A message in an alert that appears after a user signs up. The argument is the string “”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir haben einen Bestätigungslink an %@ gesendet. Tippen Sie auf diesem iPhone darauf, um Ihr Konto zu aktivieren, und melden Sie sich anschließend an. Bis zur Bestätigung Ihrer E-Mail-Adresse ist eine Anmeldung nicht möglich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We sent a confirmation link to %@. Tap it on this iPhone to activate your account, then log in. You can't log in until your email is verified."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hemos enviado un enlace de confirmación a %@. Pulse el enlace en este iPhone para activar su cuenta y, después, inicie sesión. No podrá iniciar sesión hasta que verifique su correo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous avons envoyé un lien de confirmation à %@. Ouvrez-le sur cet iPhone pour activer votre compte, puis connectez-vous. Vous ne pourrez pas vous connecter tant que votre adresse e-mail n’est pas vérifiée."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abbiamo inviato un link di conferma a %@. Lo tocchi su questo iPhone per attivare l’account, poi acceda. Non potrà accedere finché l’email non sarà verificata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ に確認リンクを送信しました。この iPhone でリンクをタップしてアカウントを有効化し、ログインしてください。メールアドレスの確認が完了するまでログインはできません。"
          }
        },
        "ko" : {
