    "Your invite is personal. One friend, one extra collection, yours to keep.": {
      "comment": "A description of how the invite works.",
      "extractionState": "manual",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre Einladung ist persönlich. Ein Freund, eine zusätzliche Sammlung, dauerhaft Ihrs."
