    "Your ticket has been created. You can find it in All Tickets. You can now add it to a Memory or Export your ticket to use it in another app." : {
      "comment" : "Tip body for the onboarding overlay in the NewTicketSuccessStep.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr Ticket wurde erstellt. Sie finden es unter „Alle Tickets“. Sie können es jetzt zu einer Erinnerung hinzufügen oder es exportieren, um es in einer anderen App zu verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your ticket has been created. You can find it in All Tickets. You can now add it to a Memory or Export your ticket to use it in another app."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Su boleto se ha creado. Lo encontrará en «Todos los boletos». Ahora puede añadirlo a un recuerdo o exportarlo para usarlo en otra aplicación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre billet a été créé. Vous le retrouverez dans « Tous les billets ». Vous pouvez désormais l’ajouter à un souvenir ou l’exporter pour l’utiliser dans une autre application."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il suo biglietto è stato creato. Lo trova in «Tutti i biglietti». Ora può aggiungerlo a un ricordo o esportarlo per usarlo in un’altra app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "チケットを作成しました。「すべてのチケット」からご確認いただけます。メモリーに追加したり、書き出して他のアプリで使用したりできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "티켓이 생성되었습니다. ‘모든 티켓’에서 확인하실 수 있습니다. 이제 메모리에 추가하거나 내보내서 다른 앱에서 사용하실 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已创建您的票券,您可以在「所有票券」中查看。现在可以将其加入回忆,或导出以在其他应用中使用。"
          }
        }
      }
    },
