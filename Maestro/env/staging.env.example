# Copy to staging.env and fill in values. staging.env is gitignored.
# Run: maestro test --env-file env/staging.env flows/

APP_ID=bearista.Lumoria-App

# Existing seeded Supabase staging account
TEST_EMAIL=qa+lumoria@example.com
TEST_PASSWORD=ReplaceMe123!

# Unique email per signup run. Your CI should inject a UUID or timestamp.
# Locally: export TEST_EMAIL_FRESH="qa+lumoria+$(date +%s)@example.com"
TEST_EMAIL_FRESH=qa+lumoria+local@example.com

# Test invite token (from Supabase fixtures)
TEST_INVITE_TOKEN=TEST_TOKEN_123
